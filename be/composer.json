{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-amqp": "*",
        "ext-ctype": "*",
        "ext-gd": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^3.10",
        "doctrine/doctrine-bundle": "^2.15",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.5",
        "guzzlehttp/guzzle": "^7.9",
        "itspire/monolog-loki": "*",
        "maestroerror/php-heic-to-jpg": "^1.0",
        "symfony/amqp-messenger": "^7.4.6",
        "symfony/asset": "^7.3",
        "symfony/console": "^7.3.1",
        "symfony/doctrine-messenger": "^7.3",
        "symfony/dotenv": "^7.3",
        "symfony/flex": "^2.8.1",
        "symfony/form": "^7.3",
        "symfony/framework-bundle": "^7.3.1",
        "symfony/http-client": "^7.3",
        "symfony/mailer": "^7.3",
        "symfony/messenger": "^7.3",
        "symfony/mime": "^7.3",
        "symfony/monolog-bundle": "*",
        "symfony/object-mapper": "^7.3",
        "symfony/runtime": "^7.3.1",
        "symfony/scheduler": "^7.4.4",
        "symfony/security-bundle": "^7.3.1",
        "symfony/twig-bundle": "^7.3.1",
        "symfony/validator": "^7.3",
        "symfony/yaml": "^7.3.1",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "migrations:sync": [
            "php bin/console doctrine:migrations:diff",
            "php bin/console doctrine:migrations:migrate -q"
        ],
        "message:consume": [
            "php bin/console messenger:consume async"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.3"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.86",
        "phpat/phpat": "*",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "*",
        "symfony/browser-kit": "^7.3",
        "symfony/css-selector": "^7.3",
        "symfony/maker-bundle": "^1.64",
        "tomasvotruba/cognitive-complexity": "^1.1"
    }
}
