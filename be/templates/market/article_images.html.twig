{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12">
                <h1>{% if article.id %}Edit{% else %}Add{% endif %} Article Images</h1>

                {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {{ form_errors(form.description) }}
                </div>

                <h3>Images</h3>
                <div class="images-collection" data-prototype="{{ form_widget(form.images.vars.prototype)|e('html_attr') }}">
                    {% for imageForm in form.images %}
                        <div class="image-item">
                            {{ form_widget(imageForm) }}
                            <span class="remove-image">&times;</span>
                        </div>
                    {% endfor %}
                </div>

                <button type="button" class="btn btn-secondary add-image add-image-btn">Add Image</button>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="{{ path('app_user_profile') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
