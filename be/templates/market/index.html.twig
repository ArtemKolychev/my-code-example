{% extends 'base.html.twig' %}

{% block title %}User Profile{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .article-image {
            width: 50px;
            height: 50px;
            object-fit: cover;
            margin-right: 15px;
        }
        .article-item {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            padding: 10px;
            border-radius: 5px;
            background-color: #f8f9fa;
        }
        .article-title {
            font-weight: bold;
            margin: 0;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row">
            <div class="col-md-12">
                <h1>Welcome, {{ user.email }}</h1>
                {% if tokenBalance is defined and tokenBalance <= 0 %}
                    <a class="btn btn-secondary disabled" aria-disabled="true" title="Vyčerpané AI tokeny">Add new items</a>
                {% else %}
                    <a href="{{ path('app_article_images') }}" class="btn btn-success">Add new items</a>
                {% endif %}
                <a href="{{ path('app_user_profile') }}" class="btn btn-success">Profile</a>

                {% if tokenBalance is defined %}
                    <div class="alert {% if tokenBalance <= 0 %}alert-danger{% elseif tokenBalance < 10000 %}alert-warning{% else %}alert-info{% endif %} mt-3 d-flex justify-content-between align-items-center">
                        <span>
                            <strong>AI tokeny:</strong>
                            {% if tokenBalance <= 0 %}
                                Vyčerpáno — kontaktujte podporu pro obnovení.
                            {% else %}
                                {{ tokenBalance|number_format(0, '.', ' ') }} zbývá
                            {% endif %}
                        </span>
                    </div>
                {% endif %}
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="mt-4 mb-3">Your Articles</h2>
                    {% if articles|length > 0 %}
{#                        <a href="{{ path('app_list_articles') }}" class="btn btn-info">Edit Articles</a>#}
                    {% endif %}
                </div>

                {% if articles|length > 0 %}
                    <div class="articles-list">
                        {% for article in articles %}
                            <div class="article-item">
                                {% if article.images|length > 0 %}

                                    <img src="{{ article.images.first.link }}" alt="{{ article.title }}" class="article-image">
                                {% else %}
                                    <div class="article-image bg-secondary d-flex justify-content-center align-items-center">
                                        <span class="text-white">No image</span>
                                    </div>
                                {% endif %}
                                <div class="flex-grow-1">
                                    <h3 class="article-title">
                                        <a href="{{ path('app_edit_article', {'id': article.id}) }}">
                                        {{ article.title }}
                                        </a>
                                    </h3>
                                    {% set articleSubs = submissions[article.id] ?? {} %}
                                    {% set isPublished = articleSubs|filter(s => s.status in ['completed', 'deleting'])|length > 0 %}
                                    {% if article.createdAt and not isPublished %}
                                        <small class="text-muted">Vytvořeno: {{ article.createdAt|date('d.m.Y H:i') }}</small>
                                    {% endif %}
                                    {% if isPublished %}
                                        {% set resultData = article.getPublicResultData() %}
                                        {% set publishUrl = resultData ? (resultData.resource starts with 'http' ? resultData.resource : ((resultData.articleUrl is defined and resultData.articleUrl starts with 'http') ? resultData.articleUrl : ((resultData.lastPage is defined and resultData.lastPage starts with 'http') ? resultData.lastPage : null))) : null %}
                                        <small class="text-muted">
                                            Zveřejněno {{ article.createdAt|date('d.m.Y H:i') }}
                                            {% if publishUrl %}
                                                na <a href="{{ publishUrl }}" target="_blank" rel="noopener noreferrer">
                                                    {% if 'sbazar.cz' in publishUrl %}Sbazar{% else %}{{ publishUrl }}{% endif %}
                                                </a>
                                            {% endif %}
                                        </small>
                                    {% endif %}
                                </div>
                                <form method="post" action="{{ path('app_delete_article', {'id': article.id}) }}" onsubmit="return confirm('Opravdu chcete smazat tento inzerát?')">
                                    <button type="submit" class="btn btn-danger btn-sm">Smazat</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p>You don't have any articles yet.</p>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
