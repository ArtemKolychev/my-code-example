{
  "title": "Bazar AI — Clicker",
  "uid": "bazar-clicker",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "jobId",
        "type": "textbox",
        "label": "Job ID",
        "current": { "value": "" }
      },
      {
        "name": "sessionId",
        "type": "textbox",
        "label": "Session ID",
        "current": { "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Session Browser Events (filter by jobId/sessionId)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{job=\"docker\", container=~\".*clicker.*\"} | json | jobId=~\"$jobId\" | sessionId=~\"$sessionId\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 2,
      "title": "Clicker Errors",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{job=\"docker\", container=~\".*clicker.*\"} | json | level=`error`",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 3,
      "title": "Clicker Activity Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "sum(rate({job=\"docker\", container=~\".*clicker.*\"}[1m]))",
          "legendFormat": "clicker logs/s"
        }
      ]
    }
  ]
}
