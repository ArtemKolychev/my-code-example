{
  "title": "Bazar AI — Trace View",
  "uid": "bazar-trace",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "jobId",
        "type": "textbox",
        "label": "Job ID",
        "current": { "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Cross-service trace for jobId=$jobId",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 24 },
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "sortOrder": "Ascending" },
      "targets": [
        {
          "datasource": "Loki",
          "expr": "{job=\"docker\"} | json | jobId=`$jobId`",
          "legendFormat": ""
        }
      ]
    }
  ]
}
